      "parameters": {
        "jsCode": "const items = $input.all();\n\n// scal wszystkie błędne linki w HTML listę\nconst htmlList = items.map(item => {\n  return `<li><a href=\"${item.json.property_link}\" target=\"_blank\">${item.json.property_link}</a></li>`;\n}).join('');\n\nreturn [\n  {\n    json: {\n      emailBody: `\n        <p>Cześć,</p>\n        <p>Podczas pobierania kanałów RSS wystąpiły błędy w następujących linkach:</p>\n        <ul>${htmlList}</ul>\n        <p>Sprawdź źródła i popraw adresy w Notion.</p>\n      `\n    }\n  }\n];\n"
      },
