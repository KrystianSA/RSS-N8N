    {
      "parameters": {
        "jsCode": "// Wyciągamy czysty HTML z wiadomości AI\nconst raw = $input.first().json.message?.content || \"\";\n\n// Usuwa początkowe i końcowe ```html ... ```\nconst cleaned = raw\n  .replace(/^```html/, '')\n  .replace(/```$/, '')\n  .trim();\n\n// Aktualna data w formacie PL\nconst date = new Date().toLocaleDateString(\"pl-PL\", {\n  day: \"2-digit\",\n  month: \"long\",\n  year: \"numeric\"\n});\n\n// Budujemy kompletny dokument HTML z CSS + nagłówkiem\nconst styled = `\n<!DOCTYPE html>\n<html lang=\"pl\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Poranny Przegląd RSS</title>\n<style>\n  body {\n    font-family: \"Helvetica Neue\", Arial, sans-serif;\n    color: #222;\n    line-height: 1.7;\n    padding: 2.5em;\n    background-color: #fff;\n    max-width: 900px;\n    margin: auto;\n  }\n  header {\n    text-align: center;\n    margin-bottom: 40px;\n  }\n  header h1 {\n    font-size: 2.4em;\n    color: #000;\n    margin-bottom: 5px;\n  }\n  header p {\n    color: #777;\n    font-size: 0.9em;\n    margin-top: 0;\n  }\n  h2 {\n    color: #e85d04;\n    margin-top: 1.4em;\n    margin-bottom: 0.4em;\n  }\n  p {\n    margin-bottom: 0.8em;\n  }\n  /* --- NOWY STYL ŹRÓDŁA --- */\n  .source {\n    display: block;\n    margin-top: 0.5em;\n    color: #666;\n    font-size: 0.85em;\n  }\n  .source a {\n    color: #e85d04;\n    text-decoration: none;\n    font-weight: bold;\n  }\n  .source a:hover {\n    text-decoration: underline;\n  }\n  .meme {\n    text-align: center;\n    margin: 1.8em 0;\n  }\n  .meme p {\n    font-style: italic;\n    color: #444;\n  }\n</style>\n</head>\n<body>\n  <header>\n    <h1>☕ Poranny Przegląd RSS</h1>\n    <p>${date}</p>\n  </header>\n\n  ${cleaned}\n\n  <footer style=\"margin-top:3em; text-align:center; font-size:0.85em; color:#777;\">\n    <p>Generowane automatycznie przez N8N – Twój redaktor AI 🤖</p>\n  </footer>\n</body>\n</html>\n`;\n\nreturn [{ json: { html: styled } }];\n"
      },
